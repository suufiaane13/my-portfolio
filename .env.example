# URL publique du site (SEO, Open Graph, canonical)
VITE_SITE_URL=https://suufiaane.netlify.app

# Analytics Plausible (optionnel — laisser vide pour désactiver)
# VITE_PLAUSIBLE_DOMAIN=suufiaane.netlify.app

# ─── Supabase (contact, leaderboard, analytics) ──────────────────────────────
# Créer un projet sur https://supabase.com → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Google AI Studio (guide audio — LOCAL ONLY, never VITE_ / never commit) ─
# https://aistudio.google.com/apikey
# GOOGLE_GENERATIVE_AI_API_KEY=AIza...
# Used by: npm run guide:scripts · npm run guide:audio
# Optional overrides:
# GUIDE_SCRIPT_MODEL=gemini-flash-latest
# GUIDE_TTS_MODEL=gemini-3.1-flash-tts-preview
# GUIDE_TTS_VOICE_FR=Charon
# GUIDE_TTS_VOICE_EN=Orus
# TTS free quota is low per model → npm run guide:audio -- --limit=8
# Strict by default (no Piper overwrite). Optional: --piper-fallback

# ─── GitHub Actions keep-alive (évite pause plan gratuit, 2×/semaine) ────────
# Repo → Settings → Secrets and variables → Actions → New repository secret
# SUPABASE_URL          = même valeur que VITE_SUPABASE_URL (sans le préfixe VITE_)
# SUPABASE_ANON_KEY     = même valeur que VITE_SUPABASE_ANON_KEY
# Workflow : .github/workflows/supabase-keepalive.yml

# ─── Admin login (Supabase Auth) ─────────────────────────────────────────────
# Dashboard → Authentication → Users → Add user (désactiver les inscriptions publiques)
# User → app_metadata : { "role": "admin" }
# Auth → URL Configuration → Site URL + Redirect URLs : https://suufiaane.netlify.app/login
# (aussi /reset-password)

# ─── Resend / contact : UNIQUEMENT dans Supabase Secrets (PAS ici) ───────────
# Dashboard → Project Settings → Edge Functions → Secrets
# RESEND_API_KEY=re_xxxxxxxx
# CONTACT_TO_EMAIL=hjisfn@gmail.com
